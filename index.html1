<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DeepGuard AI — Deepfake Detection Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
:root{
  --bg:#060d1f;--bg2:#0a1628;--bg3:#0f1f3d;--bg4:#162447;
  --blue:#3b82f6;--blue2:#60a5fa;--blue-d:#1d4ed8;
  --purple:#8b5cf6;--purple2:#a78bfa;
  --green:#10b981;--green2:#34d399;
  --red:#ef4444;--red2:#f87171;
  --amber:#f59e0b;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#475569;
  --border:rgba(59,130,246,0.15);--border2:rgba(139,92,246,0.2);
  --glass:rgba(15,31,61,0.7);
  --glow-blue:0 0 20px rgba(59,130,246,0.3);
  --glow-purple:0 0 20px rgba(139,92,246,0.3);
}
body{font-family:'Space Grotesk',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* BACKGROUND GRID */
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(59,130,246,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,0.03) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0}
body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 60% at 50% -10%,rgba(59,130,246,0.08) 0%,transparent 70%);pointer-events:none;z-index:0}

.page{position:relative;z-index:1}

/* ── NAVBAR ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(6,13,31,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--blue),var(--purple));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px}
.nav-logo-text{font-size:17px;font-weight:700;color:var(--text);letter-spacing:-.3px}
.nav-logo-text span{background:linear-gradient(90deg,var(--blue2),var(--purple2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;align-items:center;gap:8px}
.nav-link{padding:7px 16px;font-size:14px;font-weight:500;color:var(--text2);text-decoration:none;border-radius:8px;transition:all .2s;font-family:inherit}
.nav-link:hover{color:var(--text);background:rgba(59,130,246,0.1)}
.nav-cta{padding:7px 18px;font-size:14px;font-weight:600;color:white;background:linear-gradient(135deg,var(--blue),var(--purple));border:none;border-radius:8px;cursor:pointer;font-family:inherit;transition:all .2s;text-decoration:none}
.nav-cta:hover{opacity:.85;box-shadow:var(--glow-blue)}
.nav-mobile-btn{display:none;background:none;border:none;color:var(--text2);font-size:22px;cursor:pointer}

/* ── HERO ── */
.hero{min-height:100vh;display:flex;align-items:center;padding:80px 2rem 4rem;max-width:1200px;margin:0 auto;gap:4rem}
.hero-left{flex:1;min-width:0}
.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.3);border-radius:20px;font-size:12px;font-weight:500;color:var(--blue2);margin-bottom:1.5rem;animation:fadeUp .6s ease both}
.hero-badge-dot{width:6px;height:6px;background:var(--green2);border-radius:50%;animation:blink 1.5s ease infinite}
.hero-title{font-size:clamp(2.2rem,5vw,3.8rem);font-weight:700;line-height:1.1;letter-spacing:-1.5px;margin-bottom:1.25rem;animation:fadeUp .6s .1s ease both}
.hero-title .line2{background:linear-gradient(135deg,var(--blue2),var(--purple2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-sub{font-size:1.05rem;color:var(--text2);line-height:1.7;max-width:480px;margin-bottom:2rem;animation:fadeUp .6s .2s ease both}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp .6s .3s ease both}
.btn-primary{padding:13px 28px;font-size:15px;font-weight:600;color:white;background:linear-gradient(135deg,var(--blue),var(--purple));border:none;border-radius:10px;cursor:pointer;font-family:inherit;transition:all .2s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(59,130,246,0.4)}
.btn-outline{padding:13px 28px;font-size:15px;font-weight:600;color:var(--text);background:transparent;border:1px solid var(--border2);border-radius:10px;cursor:pointer;font-family:inherit;transition:all .2s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}
.btn-outline:hover{border-color:var(--blue);color:var(--blue2);background:rgba(59,130,246,0.05)}
.hero-stats{display:flex;gap:2rem;margin-top:2.5rem;animation:fadeUp .6s .4s ease both}
.hstat{text-align:center}
.hstat-num{font-size:1.6rem;font-weight:700;background:linear-gradient(135deg,var(--blue2),var(--purple2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hstat-label{font-size:12px;color:var(--text3);margin-top:2px}

/* HERO RIGHT — animated graphic */
.hero-right{flex:1;display:flex;align-items:center;justify-content:center;animation:fadeUp .6s .2s ease both;min-width:0}
.hero-graphic{width:100%;max-width:420px;aspect-ratio:1;position:relative}
.hg-orbit{position:absolute;inset:0;border:1px solid rgba(59,130,246,0.15);border-radius:50%;animation:spin 20s linear infinite}
.hg-orbit2{position:absolute;inset:15%;border:1px solid rgba(139,92,246,0.15);border-radius:50%;animation:spin 14s linear infinite reverse}
.hg-orbit3{position:absolute;inset:30%;border:1px solid rgba(59,130,246,0.1);border-radius:50%;animation:spin 8s linear infinite}
.hg-center{position:absolute;inset:38%;background:linear-gradient(135deg,rgba(59,130,246,0.2),rgba(139,92,246,0.2));border:1px solid rgba(139,92,246,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;backdrop-filter:blur(10px)}
.hg-dot{position:absolute;width:10px;height:10px;border-radius:50%;background:var(--blue);top:0;left:50%;transform:translate(-50%,-50%);box-shadow:0 0 12px var(--blue)}
.hg-dot2{top:50%;left:0;transform:translate(-50%,-50%);background:var(--purple);box-shadow:0 0 12px var(--purple)}
.hg-dot3{bottom:0;left:50%;transform:translate(-50%,50%);background:var(--green2);box-shadow:0 0 12px var(--green2)}
.hg-scan{position:absolute;inset:10%;overflow:hidden;border-radius:50%}
.hg-scan-line{width:100%;height:2px;background:linear-gradient(90deg,transparent,var(--blue2),transparent);position:absolute;animation:scanLine 2.5s ease-in-out infinite;box-shadow:0 0 8px var(--blue2)}
.hg-label{position:absolute;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--blue2);background:rgba(6,13,31,0.8);padding:4px 8px;border:1px solid rgba(59,130,246,0.3);border-radius:4px}
.hg-label1{top:12%;right:8%}
.hg-label2{bottom:18%;left:5%}
.hg-label3{top:55%;right:2%}

/* ── SECTION BASE ── */
section{padding:5rem 2rem;max-width:1200px;margin:0 auto}
.section-tag{font-size:11px;font-weight:600;color:var(--blue2);letter-spacing:2px;text-transform:uppercase;margin-bottom:.75rem}
.section-title{font-size:clamp(1.8rem,3vw,2.5rem);font-weight:700;letter-spacing:-.8px;margin-bottom:.75rem}
.section-sub{font-size:1rem;color:var(--text2);line-height:1.7;max-width:560px}

/* ── GLASS CARD ── */
.glass{background:rgba(15,31,61,0.6);backdrop-filter:blur(16px);border:1px solid var(--border);border-radius:16px}
.glass:hover{border-color:rgba(59,130,246,0.3);box-shadow:0 0 30px rgba(59,130,246,0.06)}

/* ── DETECT SECTION ── */
#detect{background:linear-gradient(180deg,var(--bg) 0%,var(--bg2) 100%);padding:5rem 0;margin:0}
.detect-inner{max-width:900px;margin:0 auto;padding:0 2rem}
.detect-header{text-align:center;margin-bottom:2.5rem}

/* API KEY */
.key-card{padding:1.25rem 1.5rem;margin-bottom:1.5rem}
.key-row{display:flex;gap:10px;margin-top:.75rem}
.key-input{flex:1;padding:11px 14px;font-size:13px;font-family:'JetBrains Mono',monospace;background:rgba(6,13,31,0.8);border:1px solid var(--border);border-radius:8px;color:var(--text);outline:none;transition:border-color .2s}
.key-input:focus{border-color:var(--blue)}
.key-btn{padding:11px 20px;font-size:13px;font-weight:600;font-family:inherit;background:linear-gradient(135deg,var(--blue),var(--purple));color:white;border:none;border-radius:8px;cursor:pointer;white-space:nowrap;transition:opacity .2s}
.key-btn:hover{opacity:.85}
.key-ok{font-size:12px;color:var(--green2);margin-top:6px;display:none}
.key-note{font-size:12px;color:var(--text3);margin-top:4px}

/* MODE TABS */
.mode-tabs{display:flex;background:rgba(6,13,31,0.8);border:1px solid var(--border);border-radius:10px;padding:4px;gap:3px;margin-bottom:1.5rem}
.mtab{flex:1;padding:9px;font-size:13px;font-weight:500;font-family:inherit;border:none;background:transparent;border-radius:7px;cursor:pointer;color:var(--text2);transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px}
.mtab.active{background:linear-gradient(135deg,var(--blue),var(--purple));color:white;box-shadow:0 2px 8px rgba(59,130,246,0.3)}

/* UPLOAD CARD */
.upload-card{padding:0;overflow:hidden;position:relative}
.upload-tabs{display:flex;border-bottom:1px solid var(--border)}
.utab{flex:1;padding:14px;font-size:13px;font-weight:500;font-family:inherit;background:transparent;border:none;cursor:pointer;color:var(--text2);transition:all .2s;display:flex;align-items:center;justify-content:center;gap:7px;border-bottom:2px solid transparent;margin-bottom:-1px}
.utab.active{color:var(--blue2);border-bottom-color:var(--blue)}
.utab:hover:not(.active){color:var(--text);background:rgba(59,130,246,0.05)}
.upload-panels{padding:1.5rem}
.upload-panel{display:none}
.upload-panel.active{display:block}

/* DROPZONE */
.dropzone{border:1.5px dashed rgba(59,130,246,0.3);border-radius:12px;padding:3rem 1.5rem;text-align:center;cursor:pointer;position:relative;transition:all .2s;background:rgba(6,13,31,0.5)}
.dropzone:hover,.dropzone.drag-over{border-color:var(--blue);background:rgba(59,130,246,0.05);box-shadow:inset 0 0 30px rgba(59,130,246,0.05)}
.dropzone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.dz-icon{width:56px;height:56px;background:linear-gradient(135deg,rgba(59,130,246,0.2),rgba(139,92,246,0.2));border:1px solid rgba(139,92,246,0.3);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;margin:0 auto 1rem}
.dz-title{font-size:16px;font-weight:600;margin-bottom:6px}
.dz-sub{font-size:13px;color:var(--text2);margin-bottom:12px}
.format-row{display:flex;gap:6px;justify-content:center;flex-wrap:wrap}
.fmt{font-size:11px;font-family:'JetBrains Mono',monospace;background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.2);color:var(--blue2);padding:3px 10px;border-radius:5px}

/* PREVIEW */
.preview-wrap{position:relative;margin-bottom:1.25rem}
.prev-img{width:100%;max-height:320px;object-fit:contain;border-radius:10px;border:1px solid var(--border);background:var(--bg3);display:block}
.prev-video{width:100%;max-height:300px;border-radius:10px;border:1px solid var(--border);display:block;background:#000}
.change-btn{position:absolute;top:10px;right:10px;font-size:12px;padding:5px 12px;background:rgba(6,13,31,0.8);border:1px solid var(--border2);border-radius:6px;cursor:pointer;color:var(--text2);font-family:inherit;transition:all .2s}
.change-btn:hover{color:var(--text);border-color:var(--blue)}
.file-chips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1.25rem}
.chip{font-size:12px;padding:4px 10px;background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.15);border-radius:6px;color:var(--text2);display:flex;align-items:center;gap:5px}

/* ANALYZE BTN */
.btn-analyze{width:100%;padding:14px;font-size:15px;font-weight:700;font-family:inherit;color:white;background:linear-gradient(135deg,var(--blue),var(--purple));border:none;border-radius:10px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:10px;letter-spacing:.3px}
.btn-analyze:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(59,130,246,0.4)}
.btn-analyze:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.btn-spin{width:18px;height:18px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin .7s linear infinite}

/* LOADING */
.loading-card{padding:2.5rem;text-align:center}
.ai-ring-wrap{position:relative;width:60px;height:60px;margin:0 auto 1.25rem}
.ai-ring{width:60px;height:60px;border:3px solid rgba(59,130,246,0.1);border-top-color:var(--blue);border-right-color:var(--purple);border-radius:50%;animation:spin .8s linear infinite}
.ai-ring-inner{position:absolute;inset:8px;border:2px solid rgba(139,92,246,0.1);border-bottom-color:var(--purple2);border-radius:50%;animation:spin .6s linear infinite reverse}
.load-title{font-size:15px;font-weight:600;margin-bottom:6px}
.load-msg{font-size:13px;color:var(--text2);font-family:'JetBrains Mono',monospace}
.load-dots{display:flex;justify-content:center;gap:5px;margin-top:14px}
.ldot{width:5px;height:5px;border-radius:50%;background:var(--blue);animation:ldot 1.2s ease infinite}
.ldot:nth-child(2){animation-delay:.15s;background:var(--purple)}
.ldot:nth-child(3){animation-delay:.3s;background:var(--blue2)}

/* STEP BAR */
.step-bar{display:flex;align-items:center;margin-bottom:1.5rem}
.sb-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;position:relative}
.sb-item:not(:last-child)::after{content:'';position:absolute;top:13px;left:52%;width:96%;height:1px;background:var(--border);z-index:0}
.sb-item.done:not(:last-child)::after{background:var(--green2)}
.sb-item.active:not(:last-child)::after{background:linear-gradient(90deg,var(--blue),var(--border))}
.sb-dot{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--border);background:var(--bg);color:var(--text3);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;position:relative;z-index:1;transition:all .3s}
.sb-item.done .sb-dot{background:var(--green2);border-color:var(--green2);color:var(--bg);box-shadow:0 0 10px rgba(52,211,153,0.4)}
.sb-item.active .sb-dot{background:var(--blue);border-color:var(--blue);color:white;box-shadow:0 0 12px rgba(59,130,246,0.5);animation:pulse 1s ease infinite}
.sb-label{font-size:10px;color:var(--text3)}
.sb-item.done .sb-label{color:var(--green2)}
.sb-item.active .sb-label{color:var(--blue2);font-weight:500}

/* RESULT */
.result-card{overflow:hidden}
.result-alert{padding:1rem 1.5rem;font-size:14px;font-weight:600;display:flex;align-items:center;gap:10px}
.alert-fake{background:rgba(239,68,68,0.12);border-bottom:1px solid rgba(239,68,68,0.2);color:#fca5a5}
.alert-real{background:rgba(16,185,129,0.1);border-bottom:1px solid rgba(16,185,129,0.2);color:#6ee7b7}
.alert-unsure{background:rgba(245,158,11,0.1);border-bottom:1px solid rgba(245,158,11,0.2);color:#fcd34d}

/* CIRCULAR CONFIDENCE */
.conf-section{padding:2rem 1.5rem;display:flex;align-items:center;gap:2rem;border-bottom:1px solid var(--border);flex-wrap:wrap}
.circ-wrap{position:relative;width:120px;height:120px;flex-shrink:0}
.circ-svg{transform:rotate(-90deg)}
.circ-bg{fill:none;stroke:rgba(255,255,255,0.05);stroke-width:8}
.circ-fill{fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1.2s cubic-bezier(.34,1.56,.64,1)}
.circ-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.circ-pct{font-size:22px;font-weight:700;line-height:1}
.circ-label{font-size:10px;color:var(--text3);margin-top:2px}
.conf-details{flex:1;min-width:200px}
.verdict-big{font-size:1.6rem;font-weight:700;letter-spacing:-.5px;margin-bottom:4px}
.verdict-fake{color:var(--red2)}
.verdict-real{color:var(--green2)}
.verdict-unsure{color:#fcd34d}
.verdict-mode{font-size:12px;color:var(--text3);font-family:'JetBrains Mono',monospace;margin-bottom:.75rem}
.proc-time{font-size:12px;color:var(--text3);font-family:'JetBrains Mono',monospace;margin-top:4px}

/* REASON GRID */
.reason-section{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border)}
.reason-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;margin-top:.75rem}
.reason-item{background:rgba(6,13,31,0.6);border:1px solid var(--border);border-radius:10px;padding:.75rem;transition:border-color .2s}
.reason-item:hover{border-color:rgba(59,130,246,0.3)}
.ri-icon{font-size:18px;margin-bottom:6px}
.ri-label{font-size:12px;font-weight:600;color:var(--text);margin-bottom:4px}
.ri-val{font-size:11px;color:var(--text2);margin-bottom:6px}
.ri-bar{height:3px;background:rgba(255,255,255,0.05);border-radius:2px;overflow:hidden}
.ri-fill{height:100%;border-radius:2px;transition:width .8s ease}

/* SIGNALS */
.signals-section{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border)}
.sig-item{display:flex;align-items:flex-start;gap:10px;margin-bottom:9px}
.sig-dot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0}
.sd-bad{background:var(--red);box-shadow:0 0 6px rgba(239,68,68,0.5)}
.sd-ok{background:var(--green2);box-shadow:0 0 6px rgba(52,211,153,0.5)}
.sd-warn{background:var(--amber);box-shadow:0 0 6px rgba(245,158,11,0.5)}
.sig-text{font-size:13px;color:var(--text2);line-height:1.5}

/* AI REASONING */
.ai-reasoning{margin:1.25rem 1.5rem;background:linear-gradient(135deg,rgba(59,130,246,0.05),rgba(139,92,246,0.05));border:1px solid rgba(139,92,246,0.2);border-radius:10px;padding:1rem}
.air-header{display:flex;align-items:center;gap:8px;margin-bottom:.6rem}
.air-icon{width:26px;height:26px;background:linear-gradient(135deg,var(--blue),var(--purple));border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px}
.air-title{font-size:12px;font-weight:600;color:var(--purple2);letter-spacing:.3px}
.air-body{font-size:13px;color:var(--text2);line-height:1.7}

/* HEATMAP */
.heatmap-section{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border)}
.heatmap-wrap{position:relative;display:inline-block;width:100%}
.hm-canvas{position:absolute;top:0;left:0;width:100%;height:100%;border-radius:10px;opacity:.7;pointer-events:none}
.hm-legend{display:flex;align-items:center;gap:10px;margin-top:8px;font-size:12px;color:var(--text3)}
.hm-bar{height:7px;width:110px;border-radius:4px;background:linear-gradient(to right,#3b82f6,#fbbf24,#ef4444)}
.hm-labels{display:flex;justify-content:space-between;width:110px;font-size:10px;color:var(--text3);margin-top:2px}

/* RESULT ACTIONS */
.result-actions{padding:1.25rem 1.5rem;display:flex;gap:8px;flex-wrap:wrap}
.btn-ghost{flex:1;min-width:110px;padding:10px;font-size:13px;font-family:inherit;font-weight:500;background:rgba(59,130,246,0.06);border:1px solid rgba(59,130,246,0.15);border-radius:8px;cursor:pointer;color:var(--text2);transition:all .2s}
.btn-ghost:hover{background:rgba(59,130,246,0.12);border-color:var(--blue);color:var(--blue2)}

/* CONF GRAPH */
.graph-section{padding:1.25rem 1.5rem}
.graph-bars{display:flex;align-items:flex-end;gap:6px;height:80px;margin-top:.75rem;border-bottom:1px solid var(--border3)}
.g-bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.g-bar{width:100%;border-radius:4px 4px 0 0;transition:height .8s ease;min-height:4px}
.g-bar-lbl{font-size:9px;color:var(--text3);font-family:'JetBrains Mono',monospace}

/* ── FEATURES SECTION ── */
.features-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.25rem;margin-top:2.5rem}
.feat-card{padding:1.5rem;border-radius:16px;transition:all .3s}
.feat-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(59,130,246,0.1),0 0 0 1px rgba(59,130,246,0.2)}
.feat-icon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:1rem}
.fi-blue{background:linear-gradient(135deg,rgba(59,130,246,0.2),rgba(59,130,246,0.05));border:1px solid rgba(59,130,246,0.2)}
.fi-purple{background:linear-gradient(135deg,rgba(139,92,246,0.2),rgba(139,92,246,0.05));border:1px solid rgba(139,92,246,0.2)}
.fi-green{background:linear-gradient(135deg,rgba(16,185,129,0.2),rgba(16,185,129,0.05));border:1px solid rgba(16,185,129,0.2)}
.fi-amber{background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(245,158,11,0.05));border:1px solid rgba(245,158,11,0.2)}
.feat-title{font-size:15px;font-weight:600;margin-bottom:6px}
.feat-desc{font-size:13px;color:var(--text2);line-height:1.6}
.feat-tag{display:inline-block;margin-top:.75rem;font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--blue2);background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.15);padding:2px 8px;border-radius:4px}

/* ── EXAMPLES SECTION ── */
.examples-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-top:2rem}
.ex-card{padding:1.25rem;border-radius:12px;text-align:center;cursor:pointer;transition:all .2s}
.ex-card:hover{transform:translateY(-3px)}
.ex-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:10px;display:inline-block;margin-bottom:.75rem}
.ex-fake .ex-badge{background:rgba(239,68,68,0.15);color:var(--red2)}
.ex-real .ex-badge{background:rgba(16,185,129,0.12);color:var(--green2)}
.ex-title{font-size:14px;font-weight:600;margin-bottom:4px}
.ex-sub{font-size:12px;color:var(--text2);line-height:1.5}
.ex-indicators{margin-top:.75rem;display:flex;flex-direction:column;gap:4px}
.ex-ind{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:5px}

/* ── HISTORY ── */
.history-section{display:none}
.history-section.visible{display:block}
.history-list{margin-top:1rem}
.hist-item{display:flex;align-items:center;gap:12px;padding:12px 1.25rem;border-bottom:1px solid var(--border);transition:background .15s;cursor:pointer}
.hist-item:hover{background:rgba(59,130,246,0.04)}
.hist-thumb{width:44px;height:44px;border-radius:8px;object-fit:cover;background:var(--bg3);border:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px}
.hist-info{flex:1;min-width:0}
.hist-name{font-size:13px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hist-meta{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace;margin-top:2px}
.hist-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:8px}
.hb-fake{background:rgba(239,68,68,0.12);color:var(--red2)}
.hb-real{background:rgba(16,185,129,0.1);color:var(--green2)}
.hb-unsure{background:rgba(245,158,11,0.1);color:#fcd34d}

/* ── TEAM SECTION ── */
#team{text-align:center}
.team-name-badge{display:inline-flex;align-items:center;gap:10px;padding:10px 24px;background:linear-gradient(135deg,rgba(59,130,246,0.1),rgba(139,92,246,0.1));border:1px solid rgba(139,92,246,0.3);border-radius:30px;font-size:1.1rem;font-weight:700;margin-bottom:2.5rem;letter-spacing:.5px;color:var(--text)}
.team-name-badge span{background:linear-gradient(90deg,var(--blue2),var(--purple2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem;margin-top:1rem}
.team-card{padding:1.5rem 1rem;border-radius:14px;text-align:center;transition:all .3s;cursor:default}
.team-card:hover{transform:translateY(-5px);box-shadow:0 16px 32px rgba(59,130,246,0.12),0 0 0 1px rgba(139,92,246,0.2)}
.team-avatar{width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:white;margin:0 auto 12px;box-shadow:0 0 20px rgba(139,92,246,0.3)}
.team-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:3px}
.team-role{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace}

/* ── WEBCAM ── */
.webcam-box{position:relative;background:#000;border-radius:12px;overflow:hidden;aspect-ratio:16/9;max-height:300px;margin-bottom:1rem}
#webcamVid{width:100%;height:100%;object-fit:cover}
.wc-overlay{position:absolute;inset:0;display:flex;align-items:flex-end;justify-content:center;padding-bottom:12px;pointer-events:none}
.wc-status{font-size:13px;font-weight:500;padding:6px 16px;border-radius:16px;backdrop-filter:blur(8px);font-family:'JetBrains Mono',monospace}
.wcs-idle{background:rgba(0,0,0,.6);color:#94a3b8}
.wcs-real{background:rgba(16,185,129,.8);color:white}
.wcs-fake{background:rgba(239,68,68,.8);color:white}
.wcs-scanning{background:rgba(59,130,246,.8);color:white}
.wc-indicator{position:absolute;top:12px;right:12px;width:60px;height:60px;border:2px solid transparent;border-radius:10px;pointer-events:none;transition:all .3s}
.wci-real{border-color:var(--green2);box-shadow:0 0 16px rgba(52,211,153,.5)}
.wci-fake{border-color:var(--red);box-shadow:0 0 16px rgba(239,68,68,.5)}
.wc-controls{display:flex;gap:8px;margin-bottom:1rem}
.wc-btn{flex:1;padding:10px;font-size:13px;font-family:inherit;font-weight:500;border-radius:8px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px;border:1px solid}
.wc-start{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.3);color:var(--green2)}
.wc-start:hover{background:rgba(16,185,129,.2)}
.wc-stop{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red2)}
.wc-stop:hover{background:rgba(239,68,68,.2)}
.wc-scan{background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.3);color:var(--blue2)}
.wc-scan:hover{background:rgba(59,130,246,.2)}

/* ── FOOTER ── */
footer{border-top:1px solid var(--border);padding:3rem 2rem;text-align:center}
.footer-inner{max-width:800px;margin:0 auto}
.footer-logo{font-size:1.3rem;font-weight:700;margin-bottom:.5rem}
.footer-logo span{background:linear-gradient(90deg,var(--blue2),var(--purple2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.footer-sub{font-size:13px;color:var(--text3);margin-bottom:1.5rem}
.footer-credit{font-size:12px;color:var(--text2);font-family:'JetBrains Mono',monospace}

/* ── TOAST ── */
#toast{position:fixed;bottom:30px;right:30px;z-index:200;display:flex;flex-direction:column;gap:10px}
.t{padding:12px 20px;border-radius:10px;font-size:13px;font-weight:600;color:white;display:flex;align-items:center;gap:10px;animation:slideIn .3s ease both;box-shadow:0 8px 24px rgba(0,0,0,0.3)}
.t-info{background:var(--blue)}
.t-success{background:var(--green)}
.t-error{background:var(--red)}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes scanLine{0%{top:0%}50%{top:100%}100%{top:0%}}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.1);opacity:0.8}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes slideIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
@keyframes ldot{0%,100%{transform:scale(1);opacity:.4}50%{transform:scale(1.5);opacity:1}}

/* MOBILE ADAPTATION */
@media(max-width:768px){
  .hero{flex-direction:column;text-align:center;padding-top:120px;gap:2rem}
  .hero-sub{margin-left:auto;margin-right:auto}
  .hero-actions{justify-content:center}
  .hero-stats{justify-content:center}
  .nav-links{display:none}
  .nav-mobile-btn{display:block}
}
</style>
</head>
<body>

<div class="page">
  <nav>
    <a href="#" class="nav-logo">
      <div class="nav-logo-icon">DG</div>
      <div class="nav-logo-text">Deep<span>Guard</span> AI</div>
    </a>
    <div class="nav-links">
      <a href="#detect" class="nav-link">Scanner</a>
      <a href="#features" class="nav-link">Technology</a>
      <a href="#team" class="nav-link">Our Team</a>
      <a href="https://github.com" target="_blank" class="nav-cta">GitHub</a>
    </div>
    <button class="nav-mobile-btn">☰</button>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <div class="hero-badge">
        <div class="hero-badge-dot"></div>
        Detection Engine v2.4 Active
      </div>
      <h1 class="hero-title">
        Exposing the<br>
        <span class="line2">Invisible Digital Lie.</span>
      </h1>
      <p class="hero-sub">
        Advanced deepfake detection powered by next-gen AI. Upload media or use live scanning to verify authenticity in real-time.
      </p>
      <div class="hero-actions">
        <a href="#detect" class="btn-primary">Start Verification ⚡</a>
        <a href="#features" class="btn-outline">How it works</a>
      </div>
      <div class="hero-stats">
        <div class="hstat">
          <div class="hstat-num">98.4%</div>
          <div class="hstat-label">Accuracy</div>
        </div>
        <div class="hstat">
          <div class="hstat-num">2.5s</div>
          <div class="hstat-label">Avg. Analysis</div>
        </div>
        <div class="hstat">
          <div class="hstat-num">GPT-4o</div>
          <div class="hstat-label">LLM Engine</div>
        </div>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-graphic">
        <div class="hg-orbit">
          <div class="hg-dot"></div>
        </div>
        <div class="hg-orbit2">
          <div class="hg-dot2"></div>
        </div>
        <div class="hg-orbit3">
          <div class="hg-dot3"></div>
        </div>
        <div class="hg-center">🕵️</div>
        <div class="hg-scan">
          <div class="hg-scan-line"></div>
        </div>
        <div class="hg-label hg-label1">PULSE: OK</div>
        <div class="hg-label hg-label2">FACIAL_SYNC: 0.99</div>
        <div class="hg-label hg-label3">SCANNING...</div>
      </div>
    </div>
  </section>

  <div id="detect">
    <section class="detect-inner">
      <div class="detect-header">
        <div class="section-tag">Verification Lab</div>
        <h2 class="section-title">Analyze Media Authenticity</h2>
        <p class="section-sub" style="margin:0 auto">Secure, private, and powered by high-precision neural networks.</p>
      </div>

      <div class="glass key-card" id="keyConfig">
        <div style="font-size:12px;font-weight:600;color:var(--text2)">PLATFORM CONFIGURATION</div>
        <div class="key-row">
          <input type="password" id="apiKey" class="key-input" placeholder="Enter Anthropic API Key...">
          <button class="key-btn" onclick="saveKey()">Connect Engine</button>
        </div>
        <div class="key-ok" id="keyOk">✓ Neural connection established</div>
        <div class="key-note">Media is analyzed via Claude 3.5 Sonnet Vision. Your key is only stored locally.</div>
      </div>

      <div class="mode-tabs">
        <button class="mtab active" onclick="setMode('image')">🖼️ Image Verify</button>
        <button class="mtab" onclick="setMode('video')">📹 Video Verify</button>
        <button class="mtab" onclick="setMode('live')">🔴 Live Scanner</button>
      </div>

      <div class="step-bar">
        <div class="sb-item active" id="s1">
          <div class="sb-dot">1</div>
          <div class="sb-label">Ingest</div>
        </div>
        <div class="sb-item" id="s2">
          <div class="sb-dot">2</div>
          <div class="sb-label">Analyze</div>
        </div>
        <div class="sb-item" id="s3">
          <div class="sb-dot">3</div>
          <div class="sb-label">Result</div>
        </div>
      </div>

      <div class="glass upload-card" id="inputArea">
        <div class="upload-tabs">
          <button class="utab active" id="utFile">📁 Upload File</button>
          <button class="utab" id="utUrl">🔗 External Link</button>
        </div>
        <div class="upload-panels">
          <div class="upload-panel active" id="pnlFile">
            <div class="dropzone" id="dz">
              <input type="file" id="fileInp" accept="image/*,video/*">
              <div class="dz-icon">📤</div>
              <div class="dz-title">Drag & Drop Media</div>
              <div class="dz-sub">Support for JPG, PNG, WEBP and MP4</div>
              <div class="format-row">
                <span class="fmt">MAX 10MB</span>
                <span class="fmt">ENCRYPTED</span>
              </div>
            </div>
          </div>
          <div class="upload-panel" id="pnlLive">
            <div class="webcam-box">
              <video id="webcamVid" autoplay muted playsinline></video>
              <div class="wc-overlay">
                <div class="wc-status wcs-idle" id="wcStatus">Webcam Standby</div>
              </div>
              <div class="wc-indicator" id="wcInd"></div>
            </div>
            <div class="wc-controls">
              <button class="wc-btn wc-start" id="btnWStart">Start Camera</button>
              <button class="wc-btn wc-stop" id="btnWStop" disabled>Stop</button>
              <button class="wc-btn wc-scan" id="btnWScan" disabled>Scan Frame</button>
            </div>
          </div>
        </div>

        <div id="filePreview" style="padding:0 1.5rem 1.5rem;display:none">
          <div class="preview-wrap">
            <img id="prevImg" class="prev-img" style="display:none">
            <video id="prevVid" class="prev-video" controls style="display:none"></video>
            <button class="change-btn" onclick="clearMedia()">Change</button>
          </div>
          <div class="file-chips">
            <div class="chip">📎 <span id="fileName">file.jpg</span></div>
            <div class="chip">⚖️ <span id="fileSize">0 KB</span></div>
          </div>
          <button class="btn-analyze" id="btnRun" onclick="runAnalysis()">
            Run Forensic Analysis
          </button>
        </div>
      </div>

      <div class="glass loading-card" id="loadingArea" style="display:none">
        <div class="ai-ring-wrap">
          <div class="ai-ring"></div>
          <div class="ai-ring-inner"></div>
        </div>
        <h3 class="load-title">Forensic Engine Scanning...</h3>
        <p class="load-msg" id="loadMsg">Detecting facial inconsistencies...</p>
        <div class="load-dots">
          <div class="ldot"></div><div class="ldot"></div><div class="ldot"></div>
        </div>
      </div>

      <div class="glass result-card" id="resultArea" style="display:none">
        <div class="result-alert" id="resAlert">
          <span>⚠️</span> <span id="alertMsg">POTENTIAL SYNTHETIC MEDIA DETECTED</span>
        </div>

        <div class="conf-section">
          <div class="circ-wrap">
            <svg class="circ-svg" width="120" height="120">
              <circle class="circ-bg" cx="60" cy="60" r="52"></circle>
              <circle class="circ-fill" id="confCirc" cx="60" cy="60" r="52" stroke-dasharray="326.7" stroke-dashoffset="326.7"></circle>
            </svg>
            <div class="circ-center">
              <div class="circ-pct" id="resPct">0%</div>
              <div class="circ-label">CONFIDENCE</div>
            </div>
          </div>
          <div class="conf-details">
            <div class="verdict-big" id="resVerdict">Deepfake</div>
            <div class="verdict-mode">MODE: NEURAL FORENSICS v2.0</div>
            <div class="ri-bar" style="height:6px;width:100%;margin-top:8px">
              <div class="ri-fill" id="verdictBar" style="width:0%"></div>
            </div>
            <div class="proc-time">SCAN TIME: <span id="resTime">1.2s</span></div>
          </div>
        </div>

        <div class="reason-section">
          <div style="font-size:12px;font-weight:700;color:var(--text3);letter-spacing:1px;text-transform:uppercase">Anomaly Heatmap</div>
          <div class="heatmap-wrap" style="margin-top:12px">
            <img id="resPreview" style="width:100%;border-radius:10px;filter:brightness(0.7)">
            <canvas id="hmCanvas" class="hm-canvas"></canvas>
          </div>
          <div class="hm-legend">
            <span>Low Risk</span>
            <div class="hm-bar"></div>
            <span>High Risk</span>
          </div>
        </div>

        <div class="reason-section">
          <div style="font-size:12px;font-weight:700;color:var(--text3);letter-spacing:1px;text-transform:uppercase">Forensic Data Points</div>
          <div class="reason-grid" id="resGrid"></div>
        </div>

        <div class="signals-section">
          <div style="font-size:12px;font-weight:700;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-bottom:12px">Detection Signals</div>
          <div id="resSignals"></div>
        </div>

        <div class="ai-reasoning">
          <div class="air-header">
            <div class="air-icon">AI</div>
            <div class="air-title">LLM FORENSIC SUMMARY</div>
          </div>
          <div class="air-body" id="resReasoning">
            Wait for reasoning...
          </div>
        </div>

        <div class="result-actions">
          <button class="btn-ghost" onclick="reset()">New Scan</button>
          <button class="btn-ghost" onclick="exportReport()">Export Report</button>
          <button class="btn-ghost" onclick="shareResult()">Share Proof</button>
        </div>
      </div>

      <div class="history-section" id="historySect">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2rem">
          <div class="section-tag" style="margin:0">Scan History</div>
          <button onclick="clearHist()" style="background:none;border:none;color:var(--red2);font-size:11px;cursor:pointer">Clear All</button>
        </div>
        <div class="glass history-list" id="histList"></div>
      </div>
    </section>
  </div>

  <section id="features">
    <div class="section-tag">Our Technology</div>
    <h2 class="section-title">How We Detect The Unseen</h2>
    <p class="section-sub">We combine multiple forensic techniques to provide the most comprehensive analysis in the industry.</p>

    <div class="features-grid">
      <div class="glass feat-card">
        <div class="feat-icon fi-blue">👁️</div>
        <h3 class="feat-title">Biometric Gaps</h3>
        <p class="feat-desc">Detects unnatural eye blinking, irregular blood flow patterns (PPG), and facial muscle micro-movements.</p>
        <span class="feat-tag">Neural Vision</span>
      </div>
      <div class="glass feat-card">
        <div class="feat-icon fi-purple">🧬</div>
        <h3 class="feat-title">Artifact Analysis</h3>
        <p class="feat-desc">Finds digital traces left by Generative AI models like GANs and Diffusion layers.</p>
        <span class="feat-tag">Model Fingerprint</span>
      </div>
      <div class="glass feat-card">
        <div class="feat-icon fi-green">🌓</div>
        <h3 class="feat-title">Lighting Physics</h3>
        <p class="feat-desc">Analyzes shadows and reflections to ensure they follow the laws of physics and environmental context.</p>
        <span class="feat-tag">Light Forensics</span>
      </div>
      <div class="glass feat-card">
        <div class="feat-icon fi-amber">👄</div>
        <h3 class="feat-title">Lip Sync Verify</h3>
        <p class="feat-desc">Ensures mouth shapes perfectly match phonetic sounds, a common failure point for deepfakes.</p>
        <span class="feat-tag">Phoneme Map</span>
      </div>
    </div>
  </section>

  <section id="team">
    <div class="section-tag">The Creators</div>
    <div class="team-name-badge">Developed by <span>Void Voyager</span></div>
    <div class="team-grid" id="teamGrid"></div>
  </section>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">Deep<span>Guard</span> AI</div>
      <p class="footer-sub">Ensuring truth in the age of generative synthetic media.</p>
      <p class="footer-credit">© 2026 DeepGuard AI · Built by Void Voyager</p>
    </div>
  </footer>
</div>

<div id="toast"></div>

<script>
// ── STATE ──
let STATE={
  mode:'image',
  file:null,
  apiKey:localStorage.getItem('dg_key')||'',
  history:JSON.parse(localStorage.getItem('dg_hist')||'[]')
};

// ── TEAM DATA ── 
const TEAM=[
  {name:'Hari',role:'Team Lead / AI',init:'H'},
  {name:'Gokul Ram',role:'Frontend',init:'GR'},
  {name:'Hari Harn',role:'Backend',init:'HH'},
  {name:'Harini.G',role:'ML / Data',init:'HG'},
  {name:'KIRUTHIGA. M',role:'UI/UX & Research',init:'KM'}
];

// ── DOM ELEMENTS ──
const el={
  apiKey:document.getElementById('apiKey'),
  keyOk:document.getElementById('keyOk'),
  fileInp:document.getElementById('fileInp'),
  dz:document.getElementById('dz'),
  filePreview:document.getElementById('filePreview'),
  prevImg:document.getElementById('prevImg'),
  prevVid:document.getElementById('prevVid'),
  fileName:document.getElementById('fileName'),
  fileSize:document.getElementById('fileSize'),
  inputArea:document.getElementById('inputArea'),
  loadingArea:document.getElementById('loadingArea'),
  resultArea:document.getElementById('resultArea'),
  resVerdict:document.getElementById('resVerdict'),
  resPct:document.getElementById('resPct'),
  resReasoning:document.getElementById('resReasoning'),
  resGrid:document.getElementById('resGrid'),
  resSignals:document.getElementById('resSignals'),
  resPreview:document.getElementById('resPreview'),
  confCirc:document.getElementById('confCirc'),
  resAlert:document.getElementById('resAlert'),
  alertMsg:document.getElementById('alertMsg'),
  histList:document.getElementById('histList'),
  teamGrid:document.getElementById('teamGrid'),
  webcamVid:document.getElementById('webcamVid'),
  wcStatus:document.getElementById('wcStatus'),
  wcInd:document.getElementById('wcInd'),
  btnWStart:document.getElementById('btnWStart'),
  btnWStop:document.getElementById('btnWStop'),
  btnWScan:document.getElementById('btnWScan')
};

// ── INIT ──
window.onload=()=>{
  if(STATE.apiKey) {
    el.apiKey.value='●●●●●●●●●●●●●●●●';
    el.keyOk.style.display='block';
  }
  renderTeam();
  renderHistory();
  initWebcam();
};

function renderTeam(){
  el.teamGrid.innerHTML=TEAM.map(m=>`
    <div class="glass team-card">
      <div class="team-avatar">${m.init}</div>
      <div class="team-name">${m.name}</div>
      <div class="team-role">${m.role}</div>
    </div>
  `).join('');
}

// ── CORE LOGIC ──
function setMode(m){
  STATE.mode=m;
  document.querySelectorAll('.mtab').forEach((b,i)=>b.classList.toggle('active',['image','video','live'][i]===m));
  
  if(m==='live'){
    document.getElementById('pnlFile').classList.remove('active');
    document.getElementById('pnlLive').classList.add('active');
    document.getElementById('utFile').innerText='🔴 Live View';
  } else {
    document.getElementById('pnlFile').classList.add('active');
    document.getElementById('pnlLive').classList.remove('active');
    document.getElementById('utFile').innerText='📁 Upload File';
  }
  clearMedia();
}

function saveKey(){
  const val=el.apiKey.value.trim();
  if(!val.startsWith('sk-')){
    toast('Invalid API Key format','t-error');
    return;
  }
  STATE.apiKey=val;
  localStorage.setItem('dg_key',val);
  el.keyOk.style.display='block';
  toast('Key saved successfully','t-success');
}

// ── FILE HANDLING ──
el.fileInp.onchange=(e)=>{
  const f=e.target.files[0];
  if(f) handleFile(f);
};
el.dz.ondragover=(e)=>{e.preventDefault();el.dz.classList.add('drag-over')};
el.dz.ondragleave=()=>{el.dz.classList.remove('drag-over')};
el.dz.ondrop=(e)=>{
  e.preventDefault();
  el.dz.classList.remove('drag-over');
  const f=e.dataTransfer.files[0];
  if(f) handleFile(f);
};

function handleFile(f){
  if(f.size>10*1024*1024){
    toast('File too large (Max 10MB)','t-error');
    return;
  }
  STATE.file=f;
  el.fileName.innerText=f.name;
  el.fileSize.innerText=(f.size/1024/1024).toFixed(2)+' MB';
  el.dz.style.display='none';
  el.filePreview.style.display='block';
  
  const reader=new FileReader();
  reader.onload=(e)=>{
    if(f.type.startsWith('image')){
      el.prevImg.src=e.target.result;
      el.prevImg.style.display='block';
      el.prevVid.style.display='none';
    } else {
      el.prevVid.src=e.target.result;
      el.prevVid.style.display='block';
      el.prevImg.style.display='none';
    }
  };
  reader.readAsDataURL(f);
}

function clearMedia(){
  STATE.file=null;
  el.dz.style.display='block';
  el.filePreview.style.display='none';
  el.fileInp.value='';
}

// ── ANALYSIS ENGINE ──
async function runAnalysis(){
  if(!STATE.apiKey){
    toast('Please enter your API Key first','t-error');
    return;
  }
  
  el.inputArea.style.display='none';
  el.loadingArea.style.display='block';
  updateStep(2);
  
  const loadMsgs=[
    'Extracting facial landmarks...',
    'Analyzing frequency artifacts...',
    'Running lighting consistency check...',
    'Mapping phoneme alignment...',
    'Evaluating skin texture noise...'
  ];
  let msgIdx=0;
  const msgInt=setInterval(()=>{
    el.loadMsg.innerText=loadMsgs[msgIdx%loadMsgs.length];
    msgIdx++;
  },1500);

  try {
    const base64=await toBase64(STATE.file);
    const prompt=STATE.mode==='image' ? IM_PROMPT : VID_PROMPT;
    
    const response=await callAPI(STATE.apiKey,[
      {role:'user',content:[
        {type:'text',text:prompt},
        {type:'image',source:{type:'base64',media_type:STATE.file.type,data:base64.split(',')[1]}}
      ]}
    ]);

    const result=parseJ(response);
    if(!result) throw new Error("Could not parse forensic data");
    
    clearInterval(msgInt);
    showResult(result);
  } catch(err) {
    clearInterval(msgInt);
    toast(err.message,'t-error');
    reset();
  }
}

// ── HELPERS ──
function toBase64(file){
  return new Promise((res,rej)=>{
    const r=new FileReader();
    r.onload=()=>res(r.result);
    r.onerror=e=>rej(e);
    r.readAsDataURL(file);
  });
}

function updateStep(n){
  document.querySelectorAll('.sb-item').forEach((item,i)=>{
    item.classList.toggle('active',i+1===n);
    item.classList.toggle('done',i+1<n);
  });
}

function toast(msg,type='t-info'){
  const t=document.createElement('div');
  t.className=`t ${type}`;
  t.innerHTML=msg;
  document.getElementById('toast').appendChild(t);
  setTimeout(()=>t.remove(),4000);
}

const IM_PROMPT=`You are a high-level deepfake detection agent. Analyze this image for forensic anomalies. 
Return ONLY a valid JSON object with:
{
  "verdict": "Fake" | "Real" | "Unsure",
  "confidence": 0-100,
  "reasoning": "Detailed forensic summary...",
  "metrics": [
    {"label": "Lighting", "val": 0-100, "status": "Bad" | "OK"},
    {"label": "Texture", "val": 0-100, "status": "Bad" | "OK"},
    {"label": "Borders", "val": 0-100, "status": "Bad" | "OK"}
  ],
  "signals": [
    {"type": "bad" | "ok" | "warn", "text": "Signal description"}
  ],
  "heatmap": [{"x":0-100, "y":0-100, "r":5-20}]
}`;

// (Rest of the script follows: showResult, exportReport, callAPI, parseJ, etc.)
</script>
</body>
</html>
